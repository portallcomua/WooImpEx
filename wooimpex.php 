// ==================== ФУНКЦІЇ ЛІЦЕНЗІЇ ====================
function wimpex_has_pro_feature($feature) {
    if ($feature === 'variable_products') {
        $license_valid = get_option('wimpex_license_valid', false);
        $license_domain = get_option('wimpex_license_domain', '');
        return $license_valid && $license_domain === $_SERVER['HTTP_HOST'];
    }
    return false;
}

function wimpex_render_pro_badge() {
    if (!wimpex_has_pro_feature('variable_products')) {
        echo '<span style="background:#ff9800; color:#fff; padding:2px 8px; border-radius:12px; font-size:11px; margin-left:8px;">PRO</span>';
    }
}

add_action('admin_init', function() {
    if (isset($_POST['wimpex_activate_license']) && isset($_POST['license_key']) && wp_verify_nonce($_POST['wimpex_activate_nonce'], 'wimpex_activate_action')) {
        $key = trim($_POST['license_key']);
        if (strlen($key) >= 16) {
            update_option('wimpex_license_valid', true);
            update_option('wimpex_license_key', $key);
            update_option('wimpex_license_domain', $_SERVER['HTTP_HOST']);
            echo '<div class="notice notice-success"><p>✅ PRO-функціонал активовано!</p></div>';
        }
    }
});

