    private function auto_match_field($column, $fields) {
        $column_clean = strtolower(trim($column));
        $map = [
            'name'        => 'post_title', 'назва' => 'post_title', 'title' => 'post_title',
            'description' => 'post_content', 'опис' => 'post_content',
            'short_desc'  => 'post_excerpt', 'короткий опис' => 'post_excerpt',
            'sku'         => '_sku', 'артикул' => '_sku',
            'price'       => '_regular_price', 'ціна' => '_regular_price', 'regular_price' => '_regular_price',
            'sale'        => '_sale_price', 'акційна' => '_sale_price',
            'stock'       => '_stock', 'кількість' => '_stock', 'quantity' => '_stock',
            'stock_status'=> '_stock_status', 'статус складу' => '_stock_status',
            'weight'      => '_weight', 'вага' => '_weight',
            'length'      => '_length', 'довжина' => '_length',
            'width'       => '_width', 'ширина' => '_width',
            'height'      => '_height', 'висота' => '_height',
            'manage_stock'=> '_manage_stock',
            'categories'  => 'product_cat', 'категорії' => 'product_cat', 'cat' => 'product_cat',
            'tags'        => 'product_tag', 'мітки' => 'product_tag',
            'attributes'  => 'attributes', 'атрибути' => 'attributes',
        ];
        return $map[$column_clean] ?? '';
    }

    public function handle_import() {
        if (!current_user_can('manage_woocommerce')) {
            wp_die('Access denied');
        }
        check_admin_referer('wsie_import_process');

        if (empty($_POST['map'])) {
            wp_redirect(add_query_arg(['step' => 1, 'error' => 'no_mapping'], wp_get_referer()));
            exit;
        }

        $mapping = array_map('sanitize_text_field', $_POST['map']);
        $csv_data = $_SESSION['wsie_csv_data'] ?? [];
        $headers = $_SESSION['wsie_headers'] ?? [];

        if (empty($csv_data) || empty($headers)) {
            wp_die('Дані CSV не знайдені, спробуйте завантажити файл знову.');
        }

        $imported = 0;
        $errors = [];

        foreach ($csv_data as $row_index => $row) {
            $product_data = [];
            foreach ($mapping as $col_idx => $field) {
                if ($field === '' || !isset($row[$col_idx])) {
                    continue;
                }
                $value = $row[$col_idx];
                if ($field === 'attributes') {
                    $product_data['attributes_raw'] = $value;
                } else {
                    $product_data[$field] = $value;
                }
            }

            if (empty($product_data['post_title'])) {
                $errors[] = "Рядок " . ($row_index+2) . ": пропущено, бо немає назви товару.";
                continue;
            }

            $product_id = $this->save_product($product_data);
            if ($product_id) {
                $imported++;
            } else {
                $errors[] = "Рядок " . ($row_index+2) . ": помилка збереження.";
            }
        }

        // Cleanup session
        unset($_SESSION['wsie_csv_data'], $_SESSION['wsie_headers']);

        $message = sprintf("Імпорт завершено. Додано/оновлено: %d товарів.", $imported);
        if (!empty($errors)) {
            $message .= '<br>Помилки:<br>' . implode('<br>', array_slice($errors, 0, 20));
        }
        set_transient('wsie_import_result', $message, 60);
        wp_redirect(add_query_arg(['step' => 1, 'result' => 1], wp_get_referer()));
        exit;
    }

    private function save_product($data) {
        $sku = $data['_sku'] ?? '';
        $existing_id = $sku ? wc_get_product_id_by_sku($sku) : 0;

        $product_args = [
            'post_type'   => 'product',
            'post_status' => 'publish',
            'post_title'  => sanitize_text_field($data['post_title']),
            'post_content'=> sanitize_post_field('post_content', $data['post_content'] ?? '', 0, 'db'),
            'post_excerpt'=> sanitize_text_field($data['post_excerpt'] ?? ''),
        ];

        if ($existing_id) {
            $product_args['ID'] = $existing_id;
            $product_id = wp_update_post($product_args);
        } else {
            $product_id = wp_insert_post($product_args);
        }

        if (!$product_id) {
            return false;
        }

        $product = wc_get_product($product_id);

        // Simple product type
        $product->set_sku($sku);
        if (isset($data['_regular_price'])) {
            $product->set_regular_price(wc_clean($data['_regular_price']));
        }
        if (isset($data['_sale_price'])) {
            $product->set_sale_price(wc_clean($data['_sale_price']));
        }
        if (isset($data['_stock'])) {
            $product->set_stock_quantity(wc_clean($data['_stock']));
            $product->set_manage_stock(true);
        }
        if (isset($data['_stock_status'])) {
            $product->set_stock_status(wc_clean($data['_stock_status']));
        }
        if (isset($data['_weight'])) {
            $product->set_weight(wc_clean($data['_weight']));
        }
        if (isset($data['_length'])) {
            $product->set_length(wc_clean($data['_length']));
        }
        if (isset($data['_width'])) {
            $product->set_width(wc_clean($data['_width']));
        }
        if (isset($data['_height'])) {
            $product->set_height(wc_clean($data['_height']));
        }

        // Categories
        if (!empty($data['product_cat'])) {
            $cats = explode('|', $data['product_cat']);
            $cat_ids = [];
            foreach ($cats as $cat) {
                $term = term_exists($cat, 'product_cat');
                if (!$term) {
                    $term = wp_insert_term($cat, 'product_cat');
                }
                if (!is_wp_error($term)) {
                    $cat_ids[] = (int) $term['term_id'];
                }
            }
            wp_set_object_terms($product_id, $cat_ids, 'product_cat');
        }

        // Tags
        if (!empty($data['product_tag'])) {
            $tags = explode('|', $data['product_tag']);
            wp_set_object_terms($product_id, $tags, 'product_tag');
        }

        // Attributes
        if (!empty($data['attributes_raw'])) {
            $this->save_product_attributes($product_id, $data['attributes_raw']);
        }

        $product->save();
        return $product_id;
    }

    private function save_product_attributes($product_id, $raw) {
        $attributes = [];
        $pairs = explode('|', $raw);
        foreach ($pairs as $pair) {
            $parts = explode(':', $pair, 2);
            if (count($parts) !== 2) continue;
            $name = sanitize_text_field($parts[0]);
            $values = array_map('trim', explode(',', $parts[1]));
            $attribute_name = wc_sanitize_taxonomy_name($name);
            $taxonomy_name = 'pa_' . $attribute_name;

            // Register global attribute if not exists
            if (!taxonomy_exists($taxonomy_name)) {
                $attribute_id = wc_create_attribute([
                    'name' => $name,
                    'slug' => $attribute_name,
                    'type' => 'select',
                    'order_by' => 'menu_order',
                ]);
                register_taxonomy($taxonomy_name, ['product']);
            }

            // Add terms
            $term_ids = [];
            foreach ($values as $value) {
                $term = term_exists($value, $taxonomy_name);
                if (!$term) {
                    $term = wp_insert_term($value, $taxonomy_name);
                }
                if (!is_wp_error($term)) {
                    $term_ids[] = (int) $term['term_id'];
                }
            }
            wp_set_object_terms($product_id, $term_ids, $taxonomy_name);

            $attributes[] = wc_get_attribute($attribute_name) ? [
                'name'         => $taxonomy_name,
                'value'        => implode(', ', $values),
                'is_visible'   => 1,
                'is_variation' => 0,
                'is_taxonomy'  => 1,
            ] : [
                'name'         => $name,
                'value'        => implode(', ', $values),
                'is_visible'   => 1,
                'is_variation' => 0,
                'is_taxonomy'  => 0,
            ];
        }

        update_post_meta($product_id, '_product_attributes', $attributes);
    }

    // ---- EXPORT ----
    public function handle_export() {
        if (!isset($_GET['wsie_export']) || !current_user_can('manage_woocommerce')) {
            return;
        }
        check_admin_referer('wsie_export');

        $products = wc_get_products(['limit' => -1, 'return' => 'objects']);
        $rows = [];
        $headers = $this->get_export_headers();

        foreach ($products as $product) {
            $row = [
                'post_title'      => $product->get_name(),
                'post_content'    => $product->get_description(),
                'post_excerpt'    => $product->get_short_description(),
                '_sku'            => $product->get_sku(),
                '_regular_price'  => $product->get_regular_price(),
                '_sale_price'     => $product->get_sale_price(),
                '_stock'          => $product->get_stock_quantity(),
                '_stock_status'   => $product->get_stock_status(),
                '_weight'         => $product->get_weight(),
                '_length'         => $product->get_length(),
                '_width'          => $product->get_width(),
                '_height'         => $product->get_height(),
                '_manage_stock'   => $product->get_manage_stock() ? 'yes' : 'no',
                'product_cat'     => $this->get_term_names($product->get_category_ids(), 'product_cat'),
                'product_tag'     => $this->get_term_names($product->get_tag_ids(), 'product_tag'),
                'attributes'      => $this->get_attributes_string($product),
            ];
            $rows[] = $row;
        }

        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename="woo_export_' . date('Y-m-d') . '.csv"');
        $output = fopen('php://output', 'w');
        fputcsv($output, $headers);
        foreach ($rows as $row) {
            fputcsv($output, $row);
        }
        fclose($output);
        exit;
    }

    private function get_export_headers() {
        return [
            'post_title', 'post_content', 'post_excerpt', '_sku', '_regular_price', '_sale_price',
            '_stock', '_stock_status', '_weight', '_length', '_width', '_height', '_manage_stock',
            'product_cat', 'product_tag', 'attributes'
        ];
    }

    private function get_term_names($term_ids, $taxonomy) {
        if (empty($term_ids)) return '';
        $terms = get_terms(['taxonomy' => $taxonomy, 'include' => $term_ids, 'fields' => 'names']);
        return implode('|', $terms);
    }

    private function get_attributes_string($product) {
        $attrs = $product->get_attributes();
        $parts = [];
        foreach ($attrs as $attr) {
            if ($attr->is_taxonomy()) {
                $terms = wp_get_post_terms($product->get_id(), $attr->get_name(), ['fields' => 'names']);
                $parts[] = $attr->get_name() . ':' . implode(',', $terms);
            } else {
                $parts[] = $attr->get_name() . ':' . $attr->get_options();
            }
        }
        return implode('|', $parts);
    }

    // ----- CSV Upload processing (AJAX-like via admin_post) -----
    public function handle_upload_csv() {
        if (!current_user_can('manage_woocommerce')) {
            wp_die('Access denied');
        }
        check_admin_referer('wsie_upload_csv');

        if (empty($_FILES['csv_file']['tmp_name'])) {
            wp_redirect(add_query_arg(['step' => 1, 'error' => 'no_file'], wp_get_referer()));
            exit;
        }

        $delimiter = isset($_POST['delimiter']) ? $_POST['delimiter'][0] : ',';
        $file = $_FILES['csv_file']['tmp_name'];

        $handle = fopen($file, 'r');
        $headers = fgetcsv($handle, 0, $delimiter);
        if (!$headers) {
            fclose($handle);
            wp_redirect(add_query_arg(['step' => 1, 'error' => 'invalid_csv'], wp_get_referer()));
            exit;
        }
        $headers = array_map('trim', $headers);

        $data = [];
        while (($row = fgetcsv($handle, 0, $delimiter)) !== false) {
            $data[] = $row;
        }
        fclose($handle);

        if (count($data) === 0) {
            wp_redirect(add_query_arg(['step' => 1, 'error' => 'empty_data'], wp_get_referer()));
            exit;
        }

        // Store in session for next step
        if (!session_id()) {
            session_start();
        }
        $_SESSION['wsie_headers'] = $headers;
        $_SESSION['wsie_csv_data'] = $data;

        wp_redirect(add_query_arg(['step' => 2], wp_get_referer()));
        exit;
    }
}

