    private function get_fields($type = 'simple') {
        $fields = [
            'post_title' => 'Назва товару', 'post_content' => 'Повний опис', 'post_excerpt' => 'Короткий опис',
            '_sku' => 'Артикул (SKU)', '_regular_price' => 'Ціна', '_sale_price' => 'Акційна ціна',
            '_stock' => 'Кількість', '_stock_status' => 'Статус складу', '_weight' => 'Вага (кг)',
            '_length' => 'Довжина (см)', '_width' => 'Ширина (см)', '_height' => 'Висота (см)',
            'product_cat' => 'Категорії (через |)', 'product_tag' => 'Теги (через |)',
            'attributes' => 'Атрибути (назва:значення1,значення2)'
        ];
        if ($type === 'variable') {
            $fields['parent_sku'] = 'SKU батьківського товару';
            $fields['variation_attributes'] = 'Атрибути варіації (назва:значення)';
            $fields['variation_price'] = 'Ціна варіації';
            $fields['variation_sku'] = 'SKU варіації';
            $fields['variation_stock'] = 'Кількість варіації';
        }
        return $fields;
    }

    public function handle_upload() {
        check_admin_referer('wimpex_upload');
        if (empty($_FILES['csv_file']['tmp_name'])) wp_redirect(add_query_arg('step', 1, wp_get_referer()));
        $delimiter = $_POST['delimiter'][0] ?? ',';
        $handle = fopen($_FILES['csv_file']['tmp_name'], 'r');
        $headers = fgetcsv($handle, 0, $delimiter);
        if (!$headers) wp_redirect(add_query_arg('step', 1, wp_get_referer()));
        $headers = array_map('trim', $headers);
        $data = [];
        while (($row = fgetcsv($handle, 0, $delimiter)) !== false) $data[] = $row;
        fclose($handle);
        session_start();
        $_SESSION['wimpex_headers'] = $headers;
        $_SESSION['wimpex_data'] = $data;
        $_SESSION['wimpex_product_type'] = $_POST['product_type'];
        wp_redirect(add_query_arg(['step' => 2], wp_get_referer()));
        exit;
    }

    public function handle_import() {
        check_admin_referer('wimpex_import');
        if (!current_user_can('manage_woocommerce')) wp_die('Access denied');
        $product_type = $_POST['product_type'];
        if ($product_type === 'variable' && !wimpex_has_pro_feature('variable_products')) {
            wp_die('⚠️ Варіативні товари доступні лише в PRO версії. <a href="'.admin_url('admin.php?page=wimpex-license').'">Активуйте ліцензію</a>');
        }
        $mapping = array_map('sanitize_text_field', $_POST['map']);
        if (isset($_POST['save_mapping'])) {
            $headers = $_SESSION['wimpex_headers'];
            $new_mapping = [];
            foreach ($headers as $i => $col) $new_mapping[$col] = $mapping[$i] ?? '';
            update_option('wimpex_saved_mapping', $new_mapping);
        }
        $data = $_SESSION['wimpex_data'];
        $imported = 0;
        if ($product_type === 'variable') {
            $imported = $this->import_variable_products($data, $mapping);
        } else {
            foreach ($data as $row) {
                $product_data = [];
                foreach ($mapping as $col_idx => $field) {
                    if ($field && isset($row[$col_idx])) {
                        if ($field === 'attributes') $product_data['attributes_raw'] = $row[$col_idx];
                        else $product_data[$field] = $row[$col_idx];
                    }
                }
                if (empty($product_data['post_title'])) continue;
                if ($this->save_product($product_data)) $imported++;
            }
        }
        unset($_SESSION['wimpex_headers'], $_SESSION['wimpex_data'], $_SESSION['wimpex_product_type']);
        echo "<div class='notice notice-success'><p>✅ Імпорт завершено. Додано/оновлено: $imported товарів.</p></div>";
        echo '<p><a href="'.admin_url('admin.php?page=wimpex').'" class="button">⬅ Повернутись</a></p>';
    }

    private function save_product($data, $type = 'simple') {
        $sku = $data['_sku'] ?? '';
        $existing = $sku ? wc_get_product_id_by_sku($sku) : 0;
        $args = ['post_type' => 'product', 'post_status' => 'publish', 'post_title' => sanitize_text_field($data['post_title'])];
        if ($existing) $args['ID'] = $existing;
        $id = $existing ? wp_update_post($args) : wp_insert_post($args);
        if (!$id) return false;
        $product = wc_get_product($id);
        if ($type === 'variable') $product = new WC_Product_Variable();
        $product->set_sku($sku);
        if (isset($data['_regular_price'])) $product->set_regular_price(wc_clean($data['_regular_price']));
        if (isset($data['_sale_price'])) $product->set_sale_price(wc_clean($data['_sale_price']));
        if (isset($data['_stock'])) { $product->set_stock_quantity(wc_clean($data['_stock'])); $product->set_manage_stock(true); }
        if (isset($data['_stock_status'])) $product->set_stock_status(wc_clean($data['_stock_status']));
        if (isset($data['_weight'])) $product->set_weight(wc_clean($data['_weight']));
        if (isset($data['_length'])) $product->set_length(wc_clean($data['_length']));
        if (isset($data['_width'])) $product->set_width(wc_clean($data['_width']));
        if (isset($data['_height'])) $product->set_height(wc_clean($data['_height']));
        if (!empty($data['product_cat'])) {
            $cat_ids = [];
            foreach (explode('|', $data['product_cat']) as $cat) { $term = term_exists($cat, 'product_cat'); if (!$term) $term = wp_insert_term($cat, 'product_cat'); if (!is_wp_error($term)) $cat_ids[] = (int)$term['term_id']; }
            wp_set_object_terms($id, $cat_ids, 'product_cat');
        }
        if (!empty($data['product_tag'])) {
            $tags = explode('|', $data['product_tag']);
            wp_set_object_terms($id, $tags, 'product_tag');
        }
        if (!empty($data['attributes_raw'])) $this->save_attributes($id, $data['attributes_raw']);
        $product->save();
        return $id;
    }

    private function save_attributes($pid, $raw) {
        $attrs = []; $pairs = explode('|', $raw);
        foreach ($pairs as $pair) {
            $parts = explode(':', $pair, 2); if (count($parts) !== 2) continue;
            $name = sanitize_text_field($parts[0]); $values = array_map('trim', explode(',', $parts[1]));
            $slug = wc_sanitize_taxonomy_name($name); $tax = 'pa_' . $slug;
            if (!taxonomy_exists($tax)) { wc_create_attribute(['name' => $name, 'slug' => $slug, 'type' => 'select']); register_taxonomy($tax, ['product']); }
            $term_ids = [];
            foreach ($values as $val) { $term = term_exists($val, $tax); if (!$term) $term = wp_insert_term($val, $tax); if (!is_wp_error($term)) $term_ids[] = (int)$term['term_id']; }
            wp_set_object_terms($pid, $term_ids, $tax);
            $attrs[] = ['name' => $tax, 'value' => implode(', ', $values), 'is_visible' => 1, 'is_taxonomy' => 1];
        }
        update_post_meta($pid, '_product_attributes', $attrs);
    }

    private function import_variable_products($data, $mapping) {
        $parents = [];
        $variations = [];
        foreach ($data as $row) {
            $item = [];
            foreach ($mapping as $col => $field) if ($field && isset($row[$col])) $item[$field] = $row[$col];
            if (!empty($item['parent_sku'])) {
                if (!isset($parents[$item['parent_sku']])) $parents[$item['parent_sku']] = [];
                $variations[] = $item;
            } else {
                $pid = $this->save_product($item, 'variable');
                if ($pid) $parents[$item['_sku']] = $pid;
            }
        }
        foreach ($variations as $var) {
            $parent_id = $parents[$var['parent_sku']] ?? 0;
            if (!$parent_id) continue;
            $variation = new WC_Product_Variation();
            $variation->set_parent_id($parent_id);
            if (!empty($var['variation_sku'])) $variation->set_sku($var['variation_sku']);
            if (!empty($var['variation_price'])) $variation->set_regular_price(wc_clean($var['variation_price']));
            if (!empty($var['variation_stock'])) { $variation->set_stock_quantity(wc_clean($var['variation_stock'])); $variation->set_manage_stock(true); }
            if (!empty($var['variation_attributes'])) {
                $attrs = [];
                $pairs = explode('|', $var['variation_attributes']);
                foreach ($pairs as $pair) {
                    $parts = explode(':', $pair, 2);
                    if (count($parts) === 2) $attrs[sanitize_title($parts[0])] = $parts[1];
                }
                $variation->set_attributes($attrs);
            }
            $variation->save();
        }
        return count($parents);
    }

    public function handle_export() {
        check_admin_referer('wimpex_export');
        if (!current_user_can('manage_woocommerce')) wp_die('Access denied');
        $products = wc_get_products(['limit' => -1]);
        $headers = ['post_title', 'post_content', 'post_excerpt', '_sku', '_regular_price', '_sale_price', '_stock', '_stock_status', '_weight', '_length', '_width', '_height', 'product_cat', 'product_tag', 'attributes'];
        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename="export_'.date('Y-m-d').'.csv"');
        $out = fopen('php://output', 'w');
        fputcsv($out, $headers);
        foreach ($products as $p) {
            fputcsv($out, [
                $p->get_name(), $p->get_description(), $p->get_short_description(), $p->get_sku(),
                $p->get_regular_price(), $p->get_sale_price(), $p->get_stock_quantity(), $p->get_stock_status(),
                $p->get_weight(), $p->get_length(), $p->get_width(), $p->get_height(),
                implode('|', wp_get_post_terms($p->get_id(), 'product_cat', ['fields'=>'names'])),
                implode('|', wp_get_post_terms($p->get_id(), 'product_tag', ['fields'=>'names'])),
                $this->get_attr_str($p)
            ]);
        }
        exit;
    }

    private function get_attr_str($p) {
        $parts = [];
        foreach ($p->get_attributes() as $a) {
            $vals = $a->is_taxonomy() ? wp_get_post_terms($p->get_id(), $a->get_name(), ['fields'=>'names']) : $a->get_options();
            $parts[] = $a->get_name() . ':' . implode(',', $vals);
        }
        return implode('|', $parts);
    }
