// ==================== ФУНКЦІЇ ЛІЦЕНЗІЇ ====================
function wimpex_get_operations_count() { return get_option('wimpex_total_operations', 0); }
function wimpex_is_license_active() {
    $license_valid = get_option('wimpex_license_valid', false);
    $license_domain = get_option('wimpex_license_domain', '');
    return $license_valid && $license_domain === $_SERVER['HTTP_HOST'];
}
function wimpex_can_perform_operation() {
    if (wimpex_is_license_active()) return true;
    return wimpex_get_operations_count() < WIMPEX_FREE_LIMIT;
}
function wimpex_get_remaining_free() { return max(0, WIMPEX_FREE_LIMIT - wimpex_get_operations_count()); }
function wimpex_increment_operations() { update_option('wimpex_total_operations', wimpex_get_operations_count() + 1); }

// Обробник активації ліцензії
add_action('admin_init', function() {
    if (isset($_POST['wimpex_activate_license']) && isset($_POST['license_key']) && wp_verify_nonce($_POST['wimpex_activate_nonce'], 'wimpex_activate_action')) {
        $key = trim($_POST['license_key']);
        if (strlen($key) >= 16) {
            update_option('wimpex_license_valid', true);
            update_option('wimpex_license_key', $key);
            update_option('wimpex_license_domain', $_SERVER['HTTP_HOST']);
            echo '<div class="notice notice-success"><p>✅ Ліцензію активовано!</p></div>';
        } else {
            echo '<div class="notice notice-error"><p>❌ Невірний ключ (мінімум 16 символів)</p></div>';
        }
    }
});

