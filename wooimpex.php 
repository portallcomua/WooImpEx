add_action('admin_post_wimpex_upload', function() {
    if (!current_user_can('manage_woocommerce')) wp_die('Немає прав');
    check_admin_referer('wimpex_up');
    $delimiter = $_POST['delimiter'][0] ?? ',';
    $h = fopen($_FILES['csv_file']['tmp_name'], 'r');
    $headers = fgetcsv($h, 0, $delimiter);
    $sample = fgetcsv($h, 0, $delimiter);
    fclose($h);
    set_transient('wimpex_data', ['headers' => $headers, 'sample' => $sample, 'file' => $_FILES['csv_file']['tmp_name']], 3600);
    wp_redirect(admin_url('admin.php?page=wimpex&step=2'));
    exit;
});

add_action('admin_post_wimpex_import', function() {
    if (!current_user_can('manage_woocommerce')) wp_die('Немає прав');
    check_admin_referer('wimpex_imp');
    $data = get_transient('wimpex_data');
    if (!$data) wp_die('Файл не знайдено');
    $mapping = array_map('sanitize_text_field', $_POST['map']);
    $h = fopen($data['file'], 'r');
    fgetcsv($h);
    $imported = 0;
    while (($row = fgetcsv($h, 0, ',')) !== false) {
        $prod = [];
        foreach ($mapping as $i => $field) if ($field && isset($row[$i])) $prod[$field] = $row[$i];
        if (empty($prod['post_title'])) continue;
        $id = wimpex_save($prod);
        if ($id) $imported++;
    }
    fclose($h);
    delete_transient('wimpex_data');
    echo '<div class="notice notice-success"><p>✅ Імпорт завершено. Додано: ' . $imported . '</p><p><a href="'.admin_url('admin.php?page=wimpex').'" class="button">⬅ Назад</a></p></div>';
});

function wimpex_save($d) {
    $sku = $d['_sku'] ?? '';
    $existing = $sku ? wc_get_product_id_by_sku($sku) : 0;
    $args = ['post_type' => 'product', 'post_status' => 'publish', 'post_title' => sanitize_text_field($d['post_title'])];
    if ($existing) $args['ID'] = $existing;
    $id = $existing ? wp_update_post($args) : wp_insert_post($args);
    if (!$id) return false;
    $p = wc_get_product($id);
    $p->set_sku($sku);
    if (isset($d['_regular_price'])) $p->set_regular_price(wc_clean($d['_regular_price']));
    if (isset($d['_sale_price'])) $p->set_sale_price(wc_clean($d['_sale_price']));
    if (isset($d['_stock'])) { $p->set_stock_quantity(wc_clean($d['_stock'])); $p->set_manage_stock(true); }
    if (!empty($d['product_cat'])) {
        $cats = [];
        foreach (explode('|', $d['product_cat']) as $c) { $t = term_exists($c, 'product_cat'); if (!$t) $t = wp_insert_term($c, 'product_cat'); if (!is_wp_error($t)) $cats[] = (int)$t['term_id']; }
        if ($cats) wp_set_object_terms($id, $cats, 'product_cat');
    }
    if (!empty($d['product_tag'])) wp_set_object_terms($id, explode('|', $d['product_tag']), 'product_tag');
    if (!empty($d['attributes'])) wimpex_save_attrs($id, $d['attributes']);
    $p->save();
    return $id;
}

function wimpex_save_attrs($pid, $raw) {
    $attrs = [];
    foreach (explode('|', $raw) as $pair) {
        $parts = explode(':', $pair, 2);
        if (count($parts) !== 2) continue;
        $name = sanitize_text_field($parts[0]); $vals = array_map('trim', explode(',', $parts[1]));
        $slug = wc_sanitize_taxonomy_name($name); $tax = 'pa_' . $slug;
        if (!taxonomy_exists($tax)) { wc_create_attribute(['name' => $name, 'slug' => $slug, 'type' => 'select']); register_taxonomy($tax, ['product']); }
        $term_ids = [];
        foreach ($vals as $val) { $t = term_exists($val, $tax); if (!$t) $t = wp_insert_term($val, $tax); if (!is_wp_error($t)) $term_ids[] = (int)$t['term_id']; }
        if ($term_ids) wp_set_object_terms($pid, $term_ids, $tax);
        $attrs[] = ['name' => $tax, 'value' => implode(', ', $vals), 'is_visible' => 1, 'is_taxonomy' => 1];
    }
    update_post_meta($pid, '_product_attributes', $attrs);
}

add_action('admin_post_wimpex_export', function() {
    if (!current_user_can('manage_woocommerce')) wp_die('Немає прав');
    check_admin_referer('wimpex_exp');
    $products = wc_get_products(['limit' => -1]);
    header('Content-Type: text/csv; charset=utf-8');
    header('Content-Disposition: attachment; filename="export_'.date('Y-m-d').'.csv"');
    $out = fopen('php://output', 'w');
    fputcsv($out, ['post_title', '_sku', '_regular_price', '_sale_price', '_stock', 'product_cat', 'product_tag']);
    foreach ($products as $p) fputcsv($out, [$p->get_name(), $p->get_sku(), $p->get_regular_price(), $p->get_sale_price(), $p->get_stock_quantity(), implode('|', wp_get_post_terms($p->get_id(), 'product_cat', ['fields'=>'names'])), implode('|', wp_get_post_terms($p->get_id(), 'product_tag', ['fields'=>'names']))]);
    exit;
});