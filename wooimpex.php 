    public function handle_export() {
        if (!current_user_can('manage_woocommerce')) {
            wp_die('❌ Доступ заборонено. Потрібні права адміністратора.');
        }
        if (!wp_verify_nonce($_GET['_wpnonce'], 'wooimpex_export')) {
            wp_die('❌ Nonce не підтверджено. Спробуйте ще раз.');
        }
        if (!wimpex_can_perform_operation()) {
            wp_die('🚫 Ліміт безкоштовної версії вичерпано. <a href="'.admin_url('admin.php?page=wooimpex-license').'">Придбайте ліцензію</a>');
        }

        $products = wc_get_products(['limit' => -1]);
        $headers = [
            'post_title', 'post_content', 'post_excerpt', '_sku', '_regular_price', '_sale_price',
            '_stock', '_stock_status', '_weight', '_length', '_width', '_height',
            'product_cat', 'product_tag', 'attributes'
        ];
        
        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename="wooimpex_export_'.date('Y-m-d_H-i').'.csv"');
        $out = fopen('php://output', 'w');
        fputcsv($out, $headers);
        
        foreach ($products as $p) {
            $cats = wp_get_post_terms($p->get_id(), 'product_cat', ['fields' => 'names']);
            $tags = wp_get_post_terms($p->get_id(), 'product_tag', ['fields' => 'names']);
            $attr_str = $this->get_attributes_string($p);
            fputcsv($out, [
                $p->get_name(),
                $p->get_description(),
                $p->get_short_description(),
                $p->get_sku(),
                $p->get_regular_price(),
                $p->get_sale_price(),
                $p->get_stock_quantity(),
                $p->get_stock_status(),
                $p->get_weight(),
                $p->get_length(),
                $p->get_width(),
                $p->get_height(),
                implode('|', $cats),
                implode('|', $tags),
                $attr_str
            ]);
        }
        fclose($out);
        wimpex_increment_operations();
        exit;
    }

    private function get_attributes_string($product) {
        $parts = [];
        foreach ($product->get_attributes() as $attr) {
            if ($attr->is_taxonomy()) $vals = wp_get_post_terms($product->get_id(), $attr->get_name(), ['fields' => 'names']);
            else $vals = $attr->get_options();
            $parts[] = $attr->get_name() . ':' . implode(',', $vals);
        }
        return implode('|', $parts);
    }
